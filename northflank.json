{
  "apiVersion": "v1.2",
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "ref": "project",
          "spec": {
            "name": "toy-app",
            "color": "#57637A",
            "networking": {
              "tailscale": {
                "authKeyTags": [],
                "enabled": false
              },
              "allowedIngressProjects": []
            },
            "region": "us-central"
          }
        },
        {
          "kind": "Workflow",
          "spec": {
            "type": "parallel",
            "context": {
              "projectId": "${refs.project.id}"
            },
            "steps": [
              {
                "kind": "CombinedService",
                "spec": {
                  "deployment": {
                    "instances": 1,
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 1024
                      },
                      "shmSize": 64
                    },
                    "docker": {
                      "configType": "default"
                    }
                  },
                  "loadBalancing": {
                    "mode": "leastConnection"
                  },
                  "buildSettings": {
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 16384
                      }
                    },
                    "dockerfile": {
                      "buildEngine": "buildkit",
                      "dockerWorkDir": "/app",
                      "dockerFilePath": "/app/Dockerfile",
                      "buildkit": {
                        "useCache": false,
                        "cacheStorageSize": 16384
                      }
                    }
                  },
                  "billing": {
                    "deploymentPlan": "nf-compute-10",
                    "buildPlan": "nf-compute-400-16"
                  },
                  "runtimeEnvironment": {},
                  "runtimeFiles": {},
                  "buildArguments": {},
                  "buildFiles": {},
                  "dockerSecretMounts": {},
                  "infrastructure": {
                    "architecture": "x86"
                  },
                  "name": "app",
                  "vcsData": {
                    "projectType": "github",
                    "accountLogin": "ewdurbin",
                    "projectUrl": "https://github.com/ewdurbin/toy-app",
                    "projectBranch": "main"
                  },
                  "ports": [],
                  "disabledCI": false,
                  "buildConfiguration": {
                    "pathIgnoreRules": [],
                    "isAllowList": false,
                    "ciIgnoreFlagsEnabled": false
                  }
                },
                "ref": "app"
              },
              {
                "kind": "Workflow",
                "spec": {
                  "type": "sequential",
                  "steps": [
                    {
                      "kind": "Addon",
                      "spec": {
                        "externalAccessEnabled": false,
                        "type": "postgresql",
                        "billing": {
                          "replicas": 1,
                          "storage": 6144,
                          "storageClass": "nvme",
                          "deploymentPlan": "nf-compute-20"
                        },
                        "tlsEnabled": true,
                        "infrastructure": {
                          "architecture": "x86"
                        },
                        "name": "database",
                        "version": "18"
                      },
                      "ref": "database"
                    },
                    {
                      "kind": "CombinedService",
                      "spec": {
                        "deployment": {
                          "instances": 1,
                          "storage": {
                            "ephemeralStorage": {
                              "storageSize": 1024
                            },
                            "shmSize": 64
                          },
                          "docker": {
                            "configType": "default"
                          }
                        },
                        "loadBalancing": {
                          "mode": "leastConnection"
                        },
                        "buildSettings": {
                          "storage": {
                            "ephemeralStorage": {
                              "storageSize": 16384
                            }
                          },
                          "dockerfile": {
                            "buildEngine": "buildkit",
                            "dockerWorkDir": "/server",
                            "dockerFilePath": "/server/Dockerfile",
                            "buildkit": {
                              "useCache": false,
                              "cacheStorageSize": 16384
                            }
                          }
                        },
                        "billing": {
                          "deploymentPlan": "nf-compute-10",
                          "buildPlan": "nf-compute-400-16"
                        },
                        "runtimeEnvironment": {},
                        "runtimeFiles": {},
                        "buildArguments": {},
                        "buildFiles": {},
                        "dockerSecretMounts": {},
                        "infrastructure": {
                          "architecture": "x86"
                        },
                        "name": "server",
                        "vcsData": {
                          "projectType": "github",
                          "accountLogin": "ewdurbin",
                          "projectUrl": "https://github.com/ewdurbin/toy-app",
                          "projectBranch": "main"
                        },
                        "ports": [],
                        "disabledCI": false,
                        "buildConfiguration": {
                          "pathIgnoreRules": [],
                          "isAllowList": false,
                          "ciIgnoreFlagsEnabled": false
                        }
                      },
                      "ref": "server"
                    },
                    {
                      "kind": "SecretGroup",
                      "spec": {
                        "type": "secret",
                        "secretType": "environment",
                        "priority": 10,
                        "secrets": {
                          "variables": {
                            "": ""
                          },
                          "files": {},
                          "dockerSecretMounts": {}
                        },
                        "addonDependencies": [
                          {
                            "addonId": "${refs.database.id}",
                            "keys": [
                              {
                                "keyName": "POSTGRES_URI",
                                "aliases": [
                                  "DATABASE_URL"
                                ]
                              }
                            ]
                          }
                        ],
                        "name": "db-secrets",
                        "restrictions": {
                          "restricted": true,
                          "nfObjects": [
                            {
                              "id": "${refs.server.id}",
                              "type": "service"
                            }
                          ],
                          "tags": []
                        }
                      },
                      "ref": "db-secrets"
                    }
                  ]
                }
              }
            ]
          }
        }
      ]
    }
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  },
  "gitops": {
    "repoUrl": "https://github.com/ewdurbin/toy-app",
    "vcsService": "github",
    "accountLogin": "ewdurbin",
    "branch": "main",
    "filePath": "/northflank.json"
  },
  "$schema": "https://api.northflank.com/v1/schemas/template"
}