{
  "$schema": "https://api.northflank.com/v1/schemas/template",
  "apiVersion": "v1.2",
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Addon",
          "ref": "database",
          "spec": {
            "name": "postgresql-${args.previewId}",
            "type": "postgresql",
            "version": "18",
            "externalAccessEnabled": false,
            "billing": {
              "replicas": 1,
              "storage": 6144,
              "storageClass": "nvme",
              "deploymentPlan": "nf-compute-20"
            },
            "tlsEnabled": true,
            "infrastructure": {
              "architecture": "x86"
            },
            "source": {
              "addonId": "${args.sourceAddonId}",
              "backupId": "latest"
            },
            "tags": ["${args.previewId}"]
          }
        },
        {
          "kind": "Workflow",
          "spec": {
            "type": "parallel",
            "steps": [
              {
                "kind": "CombinedService",
                "ref": "server",
                "spec": {
                  "name": "server-${args.previewId}",
                  "deployment": {
                    "instances": 1,
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 1024
                      },
                      "shmSize": 64
                    },
                    "docker": {
                      "configType": "default"
                    }
                  },
                  "loadBalancing": {
                    "mode": "leastConnection"
                  },
                  "buildSettings": {
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 16384
                      }
                    },
                    "dockerfile": {
                      "buildEngine": "buildkit",
                      "dockerWorkDir": "/server",
                      "dockerFilePath": "/server/Dockerfile",
                      "buildkit": {
                        "useCache": false,
                        "cacheStorageSize": 16384
                      }
                    }
                  },
                  "billing": {
                    "deploymentPlan": "nf-compute-10",
                    "buildPlan": "nf-compute-400-16"
                  },
                  "runtimeEnvironment": {},
                  "runtimeFiles": {},
                  "buildArguments": {},
                  "buildFiles": {},
                  "dockerSecretMounts": {},
                  "infrastructure": {
                    "architecture": "x86"
                  },
                  "vcsData": {
                    "projectType": "github",
                    "accountLogin": "ewdurbin",
                    "projectUrl": "https://github.com/ewdurbin/toy-app",
                    "projectBranch": "${args.branch}"
                  },
                  "ports": [
                    {
                      "internalPort": 8000,
                      "protocol": "HTTP",
                      "name": "http",
                      "public": true,
                      "domains": [],
                      "security": {
                        "policies": [],
                        "credentials": []
                      },
                      "disableNfDomain": false
                    }
                  ],
                  "healthChecks": [
                    {
                      "type": "livenessProbe",
                      "protocol": "HTTP",
                      "path": "/health",
                      "port": 8000,
                      "initialDelaySeconds": 10,
                      "periodSeconds": 30,
                      "timeoutSeconds": 3,
                      "failureThreshold": 3,
                      "successThreshold": 1
                    },
                    {
                      "type": "readinessProbe",
                      "protocol": "HTTP",
                      "path": "/health",
                      "port": 8000,
                      "initialDelaySeconds": 5,
                      "periodSeconds": 10,
                      "timeoutSeconds": 3,
                      "failureThreshold": 3,
                      "successThreshold": 1
                    }
                  ],
                  "disabledCI": false,
                  "buildConfiguration": {
                    "pathIgnoreRules": [],
                    "isAllowList": false,
                    "ciIgnoreFlagsEnabled": false
                  },
                  "tags": ["${args.previewId}"]
                }
              },
              {
                "kind": "CombinedService",
                "ref": "client",
                "spec": {
                  "name": "app-${args.previewId}",
                  "deployment": {
                    "instances": 1,
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 1024
                      },
                      "shmSize": 64
                    },
                    "docker": {
                      "configType": "default"
                    }
                  },
                  "loadBalancing": {
                    "mode": "leastConnection"
                  },
                  "buildSettings": {
                    "storage": {
                      "ephemeralStorage": {
                        "storageSize": 16384
                      }
                    },
                    "dockerfile": {
                      "buildEngine": "buildkit",
                      "dockerWorkDir": "/app",
                      "dockerFilePath": "/app/Dockerfile",
                      "buildkit": {
                        "useCache": false,
                        "cacheStorageSize": 16384
                      }
                    }
                  },
                  "billing": {
                    "deploymentPlan": "nf-compute-10",
                    "buildPlan": "nf-compute-400-16"
                  },
                  "runtimeEnvironment": {},
                  "runtimeFiles": {},
                  "buildArguments": {
                    "VITE_API_URL": "${args.VITE_API_URL}"
                  },
                  "buildFiles": {},
                  "dockerSecretMounts": {},
                  "infrastructure": {
                    "architecture": "x86"
                  },
                  "vcsData": {
                    "projectType": "github",
                    "accountLogin": "ewdurbin",
                    "projectUrl": "https://github.com/ewdurbin/toy-app",
                    "projectBranch": "${args.branch}"
                  },
                  "ports": [
                    {
                      "internalPort": 80,
                      "protocol": "HTTP",
                      "name": "http",
                      "public": true,
                      "domains": [],
                      "security": {
                        "policies": [],
                        "credentials": []
                      },
                      "disableNfDomain": false
                    }
                  ],
                  "disabledCI": false,
                  "buildConfiguration": {
                    "pathIgnoreRules": [],
                    "isAllowList": false,
                    "ciIgnoreFlagsEnabled": false
                  },
                  "tags": ["${args.previewId}"]
                }
              }
            ]
          }
        },
        {
          "kind": "SecretGroup",
          "ref": "db-secrets",
          "spec": {
            "name": "db-secrets-${args.previewId}",
            "type": "secret",
            "secretType": "environment",
            "priority": 10,
            "secrets": {
              "variables": {},
              "files": {},
              "dockerSecretMounts": {}
            },
            "addonDependencies": [
              {
                "addonId": "${refs.database.id}",
                "keys": [
                  {
                    "keyName": "POSTGRES_URI",
                    "aliases": [
                      "DATABASE_URL"
                    ]
                  }
                ]
              }
            ],
            "restrictions": {
              "restricted": true,
              "nfObjects": [
                {
                  "id": "${refs.server.id}",
                  "type": "service"
                }
              ],
              "tags": ["${args.previewId}"]
            }
          }
        }
      ]
    }
  },
  "arguments": {
    "previewId": {
      "required": true,
      "description": "Unique identifier for this preview (e.g. pr-42)"
    },
    "branch": {
      "required": true,
      "description": "Git branch to build from"
    },
    "VITE_API_URL": {
      "required": true,
      "description": "API URL pointing at the preview server"
    },
    "sourceAddonId": {
      "required": true,
      "description": "Addon ID of the production PostgreSQL to fork from"
    }
  },
  "options": {
    "autorun": false,
    "concurrencyPolicy": "allow"
  }
}
