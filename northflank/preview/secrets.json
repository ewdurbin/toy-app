{
  "$schema": "https://northflank.com/schemas/v1/template",
  "apiVersion": "v1.2",
  "name": "Preview — Secrets",
  "description": "Wires forked DB CONNECTION_STRING as DATABASE_URL, restricted by preview tag.",
  "arguments": {
    "previewId": {
      "required": true,
      "description": "Unique identifier for this preview (e.g. pr-42)"
    }
  },
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "SecretGroup",
          "spec": {
            "name": "secrets-${args.previewId}",
            "secretType": "environment",
            "priority": 10,
            "secrets": {
              "variables": {}
            },
            "addonLinks": [
              {
                "addonId": "postgresql-${args.previewId}",
                "keys": [
                  {
                    "addonKey": "CONNECTION_STRING",
                    "secretKey": "DATABASE_URL"
                  }
                ]
              }
            ],
            "restrictions": {
              "restricted": true,
              "tags": ["${args.previewId}"]
            }
          }
        }
      ]
    }
  }
}
