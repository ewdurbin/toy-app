{
  "$schema": "https://northflank.com/schemas/v1/template",
  "apiVersion": "v1.2",
  "name": "Production Stack",
  "description": "Full production deployment: Postgres addon, server, and client services.",
  "arguments": {
    "CORS_ORIGINS": {
      "required": true,
      "description": "Allowed CORS origins for the server"
    },
    "VITE_API_URL": {
      "required": true,
      "description": "API URL injected into the client build"
    }
  },
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "Project",
          "spec": {
            "name": "toy-app",
            "region": "europe-west",
            "description": "Toy App production project"
          }
        },
        {
          "kind": "Addon",
          "spec": {
            "name": "postgresql",
            "type": "postgres",
            "version": "16",
            "billing": {
              "replicas": 1,
              "storage": 4096,
              "storageClass": "ssd"
            },
            "typeSpecificSettings": {
              "postgresDatabase": "toy_app"
            }
          }
        },
        {
          "kind": "SecretGroup",
          "spec": {
            "name": "app-secrets",
            "secretType": "environment",
            "priority": 10,
            "secrets": {
              "variables": {
                "CORS_ORIGINS": "${args.CORS_ORIGINS}"
              }
            },
            "addonLinks": [
              {
                "addonId": "postgresql",
                "keys": [
                  {
                    "addonKey": "CONNECTION_STRING",
                    "secretKey": "DATABASE_URL"
                  }
                ]
              }
            ],
            "restrictions": {
              "restricted": false
            }
          }
        },
        {
          "kind": "CombinedService",
          "spec": {
            "name": "server",
            "billing": {
              "deploymentPlan": "nf-compute-20"
            },
            "deployment": {
              "instances": 1,
              "docker": {
                "configType": "default"
              },
              "internal": {
                "id": "server",
                "nfObjectType": "service"
              },
              "storage": {
                "ephemeralStorage": {
                  "storageSize": 1024
                }
              }
            },
            "ports": [
              {
                "name": "http",
                "internalPort": 8000,
                "public": true,
                "protocol": "HTTP"
              }
            ],
            "healthChecks": [
              {
                "type": "liveness",
                "protocol": "HTTP",
                "path": "/health",
                "port": 8000,
                "initialDelaySeconds": 10,
                "periodSeconds": 30,
                "failureThreshold": 3
              },
              {
                "type": "readiness",
                "protocol": "HTTP",
                "path": "/health",
                "port": 8000,
                "initialDelaySeconds": 5,
                "periodSeconds": 10,
                "failureThreshold": 3
              }
            ],
            "buildConfiguration": {
              "type": "docker",
              "dockerFilePath": "/server/Dockerfile",
              "dockerWorkDir": "/server"
            },
            "buildSettings": {
              "gitHub": {
                "branch": "main"
              }
            },
            "secretGroups": [
              {
                "id": "app-secrets"
              }
            ]
          }
        },
        {
          "kind": "CombinedService",
          "spec": {
            "name": "client",
            "billing": {
              "deploymentPlan": "nf-compute-20"
            },
            "deployment": {
              "instances": 1,
              "docker": {
                "configType": "default"
              },
              "internal": {
                "id": "client",
                "nfObjectType": "service"
              },
              "storage": {
                "ephemeralStorage": {
                  "storageSize": 1024
                }
              }
            },
            "ports": [
              {
                "name": "http",
                "internalPort": 80,
                "public": true,
                "protocol": "HTTP"
              }
            ],
            "buildConfiguration": {
              "type": "docker",
              "dockerFilePath": "/app/Dockerfile",
              "dockerWorkDir": "/app",
              "buildArguments": {
                "VITE_API_URL": "${args.VITE_API_URL}"
              }
            },
            "buildSettings": {
              "gitHub": {
                "branch": "main"
              }
            }
          }
        }
      ]
    }
  }
}
