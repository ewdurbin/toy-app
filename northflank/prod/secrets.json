{
  "$schema": "https://northflank.com/schemas/v1/template",
  "apiVersion": "v1.2",
  "name": "Production — Secrets",
  "description": "Wires addon CONNECTION_STRING as DATABASE_URL, plus CORS_ORIGINS.",
  "arguments": {
    "CORS_ORIGINS": {
      "required": true,
      "description": "Allowed CORS origins for the server"
    }
  },
  "spec": {
    "kind": "Workflow",
    "spec": {
      "type": "sequential",
      "steps": [
        {
          "kind": "SecretGroup",
          "spec": {
            "name": "app-secrets",
            "secretType": "environment",
            "priority": 10,
            "secrets": {
              "variables": {
                "CORS_ORIGINS": "${args.CORS_ORIGINS}"
              }
            },
            "addonLinks": [
              {
                "addonId": "postgresql",
                "keys": [
                  {
                    "addonKey": "CONNECTION_STRING",
                    "secretKey": "DATABASE_URL"
                  }
                ]
              }
            ],
            "restrictions": {
              "restricted": false
            }
          }
        }
      ]
    }
  }
}
